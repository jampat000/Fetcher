<service>
  <id>Fetcher</id>
  <name>Fetcher</name>
  <description>Never miss a release. Sonarr/Radarr missing + upgrade automation with web UI.</description>

  <!-- Point this at your packaged exe path -->
  <executable>%BASE%\Fetcher.exe</executable>
  <!-- PyInstaller one-folder: child must run with cwd = install dir so bundled DLLs load reliably. -->
  <workingdirectory>%BASE%</workingdirectory>
  <!-- 0.0.0.0 = listen on all interfaces (LAN access). Use 127.0.0.1 to restrict to this machine. -->
  <arguments>--host 0.0.0.0 --port 8765</arguments>
  <!-- JWT: Do NOT set FETCHER_JWT_SECRET here with %VAR% expansion — an empty expansion overrides
       the process environment and breaks the service when the machine variable is unset.
       Packaged Fetcher loads or creates a stable secret under %ProgramData%\Fetcher\machine-jwt-secret.
       Optional: set machine-level FETCHER_JWT_SECRET to override that file (inherited by the service). -->
  <!-- Optional: override data folder (default is %ProgramData%\Fetcher). Set machine FETCHER_DATA_DIR and uncomment:
  <env name="FETCHER_DATA_DIR" value="%FETCHER_DATA_DIR%"/>
  -->

  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>8</keepFiles>
  </log>

  <onfailure action="restart" delay="5 sec"/>
  <onfailure action="restart" delay="10 sec"/>
  <onfailure action="restart" delay="20 sec"/>
</service>
